# Template for /config/secrets.yaml — DO NOT commit real values to git.
#
# The blueos-site-esphome setup wizard (port 80 → "Open") writes this file for you:
# it fetches the live BlueOS hostname from Beacon and fills mqtt_broker as
# "{hostname}.local" (not a hardcoded blueos.local), and generates
# api_encryption_key / ota_password if they are missing. You only need to type
# the Wi-Fi SSID/password once in the wizard.
#
# You can also edit this file by hand (it lives on the bind-mounted volume at
# /usr/blueos/extensions/esphome/secrets.yaml on the BlueOS host) if you prefer
# not to use the wizard.

# Left blank on purpose — fill in via the wizard, or type real values here
# for local testing (never commit real credentials to git).
wifi_ssid: ""
wifi_password: ""

# Filled by the wizard from Beacon: GET http://host.docker.internal:9111/v1.0/hostname
# -> "{hostname}.local". Falls back to a static IP if mDNS is unreliable on-site.
mqtt_broker: "blueos.local"
mqtt_username: ""
mqtt_password: ""

# Left blank on purpose: the wizard generates a real random value the first
# time you click "Save configuration" (32 random bytes, base64).
api_encryption_key: ""
# Left blank on purpose: the wizard generates a real random hex string on
# first save.
ota_password: ""
